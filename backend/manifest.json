{
  "id": "knowledge",
  "name": "Knowledge / RAG",
  "version": "0.1.0",
  "coreVersion": "^0.1.0",
  "dependencies": ["ai", "minio"],
  "provides": ["knowledge.Retriever"],
  "consumes": ["ai.LLM", "minio.Storage"],
  "permissions": ["knowledge.view", "knowledge.ingest"],
  "routes": ["/api/knowledge"],
